# -------------------------
# PostgreSQL + AGE settings
# -------------------------
PGHOST=pg-age
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=appdb
PGSSLMODE=disable
GRAPH_NAME=customer_graph

# Local pg-age container bootstrap settings
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=appdb

# --------------------------------------------
# FastAPI -> MCP endpoint (internal override)
# --------------------------------------------
MCP_ENDPOINT=http://mcp-server:3000/mcp

# ------------------------------------------------------
# Azure AI Foundry / Azure OpenAI via Entra service principal
# ------------------------------------------------------
# DefaultAzureCredential in af_fastapi uses these in container.
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=

# Foundry / Azure OpenAI endpoint + model deployment
# Example endpoint: https://<resource-name>.cognitiveservices.azure.com/
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Optional key-based auth fallback. Used only when service principal is not configured.
AZURE_OPENAI_API_KEY=

# -------------------------
# Redis (SSE pub/sub bus)
# -------------------------
# Auto-configured in docker-compose. Override for external Redis.
# REDIS_URL=redis://redis:6379/0
