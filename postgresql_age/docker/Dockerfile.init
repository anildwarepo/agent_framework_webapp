# Lightweight one-shot container that initialises PostgreSQL AGE
# and loads graph data into the local pg-age container.
FROM python:3.12-slim

WORKDIR /app

# System deps for psycopg binary
RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq-dev gcc postgresql-client \
    && rm -rf /var/lib/apt/lists/*

# Python deps (only what the loader scripts need)
RUN pip install --no-cache-dir \
    "psycopg[binary]>=3.2" \
    "psycopg_pool>=3.2" \
    python-dotenv

# Copy loader scripts
COPY load_data/ /app/load_data/

# Copy graph data
COPY data/ /app/data/

# Copy entrypoint
COPY docker/init-entrypoint.sh /app/init-entrypoint.sh
RUN chmod +x /app/init-entrypoint.sh

ENV PYTHONUNBUFFERED=1
ENV DATA_DIR=/app/data

ENTRYPOINT ["/app/init-entrypoint.sh"]
